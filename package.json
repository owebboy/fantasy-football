{
  "name": "fantasy-football-2024",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.node.json",
    "check:all": "npm run check && npm run lint:check",
    "data:refresh": "tsx src/data/scrape-all.ts && tsx src/data/merge.ts && node transform-data.js",
    "data:transform": "tsx src/data/merge.ts && node transform-data.js",
    "data:parse-espn": "tsx src/data/scrapers/espn.ts",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.9.3",
    "cheerio": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}
